---
const faqs = [
  {
    q: 'Do interviewers need an account?',
    a: 'No. They get a magic link. No login ever.',
  },
  {
    q: 'How does AI screening work?',
    a: 'Add JD to board, upload resumes, AI ranks every candidate with match score instantly.',
  },
  {
    q: 'Is data secure?',
    a: 'Yes. Encrypted, stored securely, never shared.',
  },
  {
    q: 'Built for Indian companies?',
    a: 'Yes. INR pricing, Indian workflows, Naukri and LinkedIn integration coming soon.',
  },
  {
    q: 'What after free trial?',
    a: 'Continue free plan or upgrade. No card needed to start.',
  },
];
---

<section id="faq" class="section faq">
  <div class="section-inner">
    <h2 class="section-title">FAQ</h2>
    <div class="faq-list">
      {faqs.map((item) => (
        <details class="faq-item">
          <summary class="faq-q">{item.q}</summary>
          <p class="faq-a">{item.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-list {
    max-width: 36rem;
    margin: 0 auto;
  }

  .faq-item {
    border-bottom: 1px solid var(--border-default);
    padding: 1rem 0;
  }

  .faq-item:first-child {
    padding-top: 0;
  }

  .faq-q {
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    list-style: none;
    padding-right: 1.5rem;
    position: relative;
  }

  .faq-q::-webkit-details-marker {
    display: none;
  }

  .faq-q::after {
    content: '+';
    position: absolute;
    right: 0;
    top: 0;
    color: var(--text-muted);
    font-size: 1.25rem;
  }

  .faq-item[open] .faq-q::after {
    content: '−';
  }

  .faq-a {
    font-size: 0.9375rem;
    color: var(--text-muted);
    margin: 0.75rem 0 0;
    line-height: 1.6;
  }
</style>
