---
const features = [
  {
    title: 'AI Resume Screening',
    desc: 'Bulk upload resumes, AI ranks every candidate against your job description with match score, skills analysis, and hire recommendation.',
  },
  {
    title: 'Kanban Interview Pipeline',
    desc: 'Visual drag and drop board to track candidates across custom hiring stages. Create boards per role or team.',
  },
  {
    title: 'Built-in Coding Assessments',
    desc: 'Unique coding link per candidate. Monaco-powered editor in browser. No candidate login needed. Code saved and reviewed in candidate profile.',
  },
  {
    title: 'Magic Link Feedback',
    desc: 'Interviewers get unique link after session. No login needed. Rate candidate, add notes, submit Pass/Hold/Fail in 2 minutes.',
  },
  {
    title: 'Automated Email Workflows',
    desc: 'Interview invites, coding links, feedback reminders all sent automatically.',
  },
  {
    title: 'Real-time Notifications',
    desc: 'In-app bell and email alerts when candidate submits code or interviewer submits feedback.',
  },
  {
    title: 'Board Management',
    desc: 'Create separate boards per role or department. Engineering, Sales, HR — all separate pipelines.',
  },
  {
    title: 'Candidate Detail Drawer',
    desc: 'Full candidate profile with resume, AI analysis, submitted code, and interviewer feedback all in one place.',
  },
];
---

<section id="features" class="section features">
  <div class="section-inner">
    <h2 class="section-title">Everything you need to hire better</h2>
    <p class="section-desc">One platform for screening, assessing, and collecting feedback.</p>
    <div class="features-grid">
      {features.map((f) => (
        <article class="feature-card">
          <h3 class="feature-title">{f.title}</h3>
          <p class="feature-desc">{f.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .features .section-desc {
    margin-bottom: 3rem;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(18rem, 1fr));
    gap: 1.5rem;
  }

  .feature-card {
    padding: 1.5rem;
    background: var(--surface-card);
    border: 1px solid var(--border-default);
    border-radius: 12px;
    transition: border-color 0.2s;
  }

  .feature-card:hover {
    border-color: rgba(99, 102, 241, 0.5);
  }

  .feature-title {
    font-size: 1.0625rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
  }

  .feature-desc {
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
  }
</style>
