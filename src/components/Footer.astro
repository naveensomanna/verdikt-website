---
const productLinks = [
  { href: '#features', label: 'Features' },
  { href: '#pricing', label: 'Pricing' },
  { href: '#', label: 'Changelog' },
  { href: '#', label: 'Roadmap' },
];
const companyLinks = [
  { href: '#', label: 'About' },
  { href: '#', label: 'Blog' },
  { href: '#', label: 'Careers' },
  { href: '#', label: 'Contact' },
];
const legalLinks = [
  { href: '#', label: 'Privacy Policy' },
  { href: '#', label: 'Terms of Service' },
  { href: '#', label: 'Security' },
];
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-grid">
      <div class="footer-col">
        <span class="footer-col-title">Product</span>
        <ul>
          {productLinks.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>
      <div class="footer-col">
        <span class="footer-col-title">Company</span>
        <ul>
          {companyLinks.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>
      <div class="footer-col">
        <span class="footer-col-title">Legal</span>
        <ul>
          {legalLinks.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p>© 2026 Verdikt. Built for Indian hiring teams 🇮🇳</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    margin-top: auto;
    padding: var(--section-padding) 1.5rem 2rem;
    border-top: 1px solid var(--border-default);
    background: var(--surface-card);
  }

  .footer-inner {
    max-width: var(--content-width);
    margin: 0 auto;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem 3rem;
    margin-bottom: 3rem;
  }

  .footer-col-title {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .footer-col ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-col a {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.9375rem;
    transition: color 0.2s;
  }

  .footer-col a:hover {
    color: var(--text-primary);
  }

  .footer-col li {
    margin-bottom: 0.5rem;
  }

  .footer-bottom {
    padding-top: 2rem;
    border-top: 1px solid var(--border-default);
  }

  .footer-bottom p {
    margin: 0;
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  @media (max-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
