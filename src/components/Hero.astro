---
---

<section class="hero">
  <div class="hero-inner">
    <h1 class="hero-title">Interview management for modern teams</h1>
    <p class="hero-sub">Built for Indian hiring teams 🇮🇳</p>
    <p class="hero-desc">
      An all-in-one HR Interview Tracking SaaS platform that helps hiring teams manage candidates,
      screen resumes with AI, conduct coding assessments, and collect interviewer feedback — all in one place.
    </p>
    <div class="hero-actions">
      <a href="https://verdkit.vercel.app/register" class="btn btn-primary" target="_blank" rel="noopener noreferrer">Start free trial</a>
      <a href="#features" class="btn btn-ghost">See how it works</a>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: clamp(4rem, 12vw, 8rem) 1.5rem;
    text-align: center;
  }

  .hero-inner {
    max-width: 42rem;
    margin: 0 auto;
  }

  .hero-title {
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin: 0 0 0.5rem;
  }

  .hero-sub {
    font-size: 1.25rem;
    color: var(--text-muted);
    margin: 0 0 1.5rem;
    font-weight: 500;
  }

  .hero-desc {
    font-size: 1.0625rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin: 0 0 2rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.5rem;
    font-size: 0.9375rem;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    transition: opacity 0.2s, transform 0.15s, background 0.2s;
  }

  .btn-primary {
    background: var(--primary-500);
    color: white;
  }

  .btn-primary:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  .btn-ghost {
    color: var(--text-primary);
    border: 1px solid var(--border-default);
    background: transparent;
  }

  .btn-ghost:hover {
    background: var(--surface-card);
  }
</style>
