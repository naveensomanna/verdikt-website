---
const comparisons = [
  {
    vs: 'vs Greenhouse',
    points: ['10x cheaper', 'AI screening built in', 'No complex setup', 'Ready in 10 minutes'],
  },
  {
    vs: 'vs Ashby',
    points: ['Half the price', 'Magic link feedback', 'No interviewer login needed', 'Built for Indian teams'],
  },
  {
    vs: 'vs interview.io',
    points: ['Full ATS included', 'AI resume screening', 'Kanban pipeline', 'Not just coding assessments'],
  },
];
---

<section class="section competitors">
  <div class="section-inner">
    <h2 class="section-title">Built to beat the rest</h2>
    <p class="section-desc">Same workflow, better price and less friction.</p>
    <div class="comparison-grid">
      {comparisons.map((c) => (
        <article class="comparison-card">
          <h3 class="comparison-vs">{c.vs}</h3>
          <ul class="comparison-points">
            {c.points.map((p) => (
              <li>{p}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .comparison-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .comparison-card {
    padding: 1.5rem;
    background: var(--surface-card);
    border: 1px solid var(--border-default);
    border-radius: 12px;
  }

  .comparison-vs {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-muted);
    margin: 0 0 1rem;
  }

  .comparison-points {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .comparison-points li {
    font-size: 0.9375rem;
    color: var(--text-primary);
    padding: 0.35rem 0;
    padding-left: 1.25rem;
    position: relative;
  }

  .comparison-points li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--success);
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .comparison-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
