---
const rows = [
  { feature: 'Price', verdikt: 'From ₹0', greenhouse: '10x more', ashby: '2x more', interview: 'Different model' },
  { feature: 'AI resume screening', verdikt: '✓', greenhouse: 'Paid add-on', ashby: 'Limited', interview: '✓' },
  { feature: 'Magic link feedback', verdikt: '✓', greenhouse: '—', ashby: '—', interview: '—' },
  { feature: 'No interviewer login', verdikt: '✓', greenhouse: '—', ashby: '—', interview: '—' },
  { feature: 'Setup time', verdikt: '~10 min', greenhouse: 'Complex', ashby: 'Complex', interview: 'N/A' },
  { feature: 'Full ATS + Kanban', verdikt: '✓', greenhouse: '✓', ashby: '✓', interview: 'Coding focus' },
  { feature: 'Built for Indian teams', verdikt: '✓ INR', greenhouse: '—', ashby: '—', interview: '—' },
];
---

<section class="section competitors" data-aos="fade-up">
  <div class="section-inner">
    <h2 class="section-title" data-aos="fade-up">Built to beat the rest</h2>
    <p class="section-desc" data-aos="fade-up">Same workflow, better price and less friction.</p>
    <div class="table-wrap">
      <table class="comparison-table">
        <thead>
          <tr>
            <th class="col-feature">Feature</th>
            <th class="col-verdikt">Verdikt</th>
            <th class="col-other">Greenhouse</th>
            <th class="col-other">Ashby</th>
            <th class="col-other">interview.io</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((row) => (
            <tr>
              <td class="col-feature">{row.feature}</td>
              <td class="col-verdikt"><span class={row.verdikt === '✓' ? 'cell-check' : ''}>{row.verdikt}</span></td>
              <td class="col-other">{row.greenhouse}</td>
              <td class="col-other">{row.ashby}</td>
              <td class="col-other">{row.interview}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .table-wrap {
    overflow-x: auto;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-default);
    background: var(--surface-card);
  }

  .comparison-table {
    width: 100%;
    min-width: 36rem;
    border-collapse: collapse;
    font-size: 0.9375rem;
  }

  .comparison-table th,
  .comparison-table td {
    padding: 0.875rem 1rem;
    text-align: left;
    border-bottom: 1px solid var(--border-default);
  }

  .comparison-table thead th {
    font-weight: 600;
    color: var(--text-primary);
    background: var(--surface-3);
  }

  .comparison-table tbody tr:last-child td {
    border-bottom: none;
  }

  .comparison-table .col-feature {
    color: var(--text-muted);
    width: 28%;
  }

  .comparison-table .col-verdikt {
    font-weight: 500;
    color: var(--text-primary);
    background: rgba(99, 102, 241, 0.06);
  }

  .cell-check {
    color: var(--success);
  }

  .comparison-table .col-other {
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .table-wrap {
      margin: 0 -1rem;
      border-radius: 0;
      border-left: none;
      border-right: none;
    }
  }
</style>
