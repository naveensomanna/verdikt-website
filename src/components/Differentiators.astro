---
const points = [
  'AI screens 100 resumes in seconds ranked against your exact job description',
  'Magic feedback link — interviewers submit feedback with zero login friction',
  'Code + feedback + AI analysis all visible in one candidate drawer',
  'Built specifically for Indian hiring teams with INR pricing',
  '10x cheaper than Greenhouse and Ashby with same core workflow',
];
---

<section class="section diff" data-aos="fade-up">
  <div class="section-inner">
    <h2 class="section-title" data-aos="fade-up">Why Verdikt</h2>
    <ul class="diff-list">
      {points.map((p) => (
        <li class="diff-item"><span>{p}</span></li>
      ))}
    </ul>
  </div>
</section>

<style>
  .diff .section-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .diff .section-title {
    margin-bottom: 2rem;
    text-align: center;
  }

  .diff-list {
    list-style: none;
    margin: 0;
    padding: 0;
    width: 100%;
    max-width: 42rem;
    display: grid;
    gap: 0;
  }

  .diff-item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.75rem 1rem;
    align-items: start;
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.6;
    padding: 0.625rem 0;
    border-bottom: 1px solid var(--border-subtle);
  }

  .diff-item:last-child {
    border-bottom: none;
  }

  .diff-item::before {
    content: '';
    grid-column: 1;
    width: 0.5rem;
    height: 0.5rem;
    margin-top: 0.4em;
    background: var(--primary-500);
    border-radius: 50%;
    flex-shrink: 0;
  }

  .diff-item span {
    grid-column: 2;
    min-width: 0;
  }
</style>
