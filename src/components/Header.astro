---
import logo from '../assets/verdkit_logo.svg';

const navLinks = [
  { href: '#features', label: 'Features' },
  { href: '#pricing', label: 'Pricing' },
  { href: '#faq', label: 'FAQ' },
];
---

<header class="header" role="banner">
  <div class="header-inner">
    <a href="/" class="logo" aria-label="Verdikt home">
      <img src={logo.src} alt="" width="32" height="32" class="logo-img" />
      <span class="logo-text">Verdikt</span>
    </a>
    <nav class="nav" aria-label="Main">
      <ul class="nav-list">
        {navLinks.map((link) => (
          <li><a href={link.href} class="nav-link">{link.label}</a></li>
        ))}
      </ul>
    </nav>
    <div class="header-actions">
      <a href="https://verdkit.vercel.app/login" class="login-link" target="_blank" rel="noopener noreferrer">Log in</a>
      <a href="https://verdkit.vercel.app/register" class="cta" target="_blank" rel="noopener noreferrer">Start free trial</a>
    </div>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    flex-shrink: 0;
    background: linear-gradient(180deg, var(--header-from) 0%, var(--header-via) 50%, var(--header-to) 100%);
    border-bottom: 1px solid var(--border-default);
    box-shadow: var(--shadow-header);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 3.5rem;
    padding: 0.75rem 1.5rem;
    max-width: var(--content-width);
    margin: 0 auto;
  }

  .logo {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
  }

  .logo:hover {
    opacity: 0.9;
  }

  .logo-img {
    display: block;
    width: 32px;
    height: 32px;
  }

  .logo-text {
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }

  .nav {
    flex: 1;
    display: flex;
    justify-content: center;
    min-width: 0;
  }

  .nav-list {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    white-space: nowrap;
    transition: color 0.2s;
  }

  .nav-link:hover {
    color: var(--text-primary);
  }

  .header-actions {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .login-link {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    transition: color 0.2s;
  }

  .login-link:hover {
    color: var(--text-primary);
  }

  .cta {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem 1rem;
    min-height: 2.25rem;
    background: var(--primary-500);
    color: white;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: var(--radius-md);
    transition: opacity 0.2s, transform 0.15s;
  }

  .cta:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  @media (max-width: 640px) {
    .header-inner {
      padding: 0.75rem 1rem;
      gap: 0.75rem;
    }

    .nav-list {
      gap: 1rem;
    }

    .nav-link {
      font-size: 0.8125rem;
    }

    .cta {
      padding: 0.5rem 0.75rem;
      font-size: 0.8125rem;
    }
  }

  @media (max-width: 480px) {
    .nav {
      display: none;
    }
  }
</style>
