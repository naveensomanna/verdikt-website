---
const steps = [
  {
    step: 1,
    title: 'Create a Board',
    desc: 'Set up a board for each role with job description and required skills.',
  },
  {
    step: 2,
    title: 'Upload Resumes',
    desc: 'Drop in all resumes. AI screens and ranks every candidate against your JD instantly.',
  },
  {
    step: 3,
    title: 'Send Coding Links',
    desc: 'Shortlisted candidates get unique link to complete coding assessment in browser.',
  },
  {
    step: 4,
    title: 'Review and Decide',
    desc: 'See code, feedback, and AI analysis in one place. Make faster hire decisions.',
  },
];
---

<section class="section how">
  <div class="section-inner">
    <h2 class="section-title">How it works</h2>
    <p class="section-desc">From JD to hire in four steps.</p>
    <div class="steps">
      {steps.map((s) => (
        <article class="step-card">
          <span class="step-num">{s.step}</span>
          <h3 class="step-title">{s.title}</h3>
          <p class="step-desc">{s.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .step-card {
    padding: 1.5rem;
    background: var(--surface-card);
    border: 1px solid var(--border-default);
    border-radius: 12px;
    position: relative;
  }

  .step-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    background: var(--primary-500);
    color: white;
    font-size: 0.875rem;
    font-weight: 700;
    border-radius: 8px;
    margin-bottom: 1rem;
  }

  .step-title {
    font-size: 1.0625rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
  }

  .step-desc {
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 900px) {
    .steps {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 500px) {
    .steps {
      grid-template-columns: 1fr;
    }
  }
</style>
