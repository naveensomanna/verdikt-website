---
// Verdikt — Interview management for modern teams
import '../styles/design-tokens.css';
import '@fontsource/geist-sans/400.css';
import '@fontsource/geist-sans/500.css';
import '@fontsource/geist-sans/600.css';
import '@fontsource/geist-sans/700.css';
import '@fontsource/geist-mono/400.css';
import '@fontsource/geist-mono/500.css';
import '@fontsource/geist-mono/600.css';
import '@fontsource/geist-mono/700.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const { title = 'Verdikt — Interview management for modern teams', description = 'All-in-one HR Interview Tracking SaaS for Indian hiring teams. AI resume screening, Kanban pipeline, coding assessments, magic link feedback. Built for Indian hiring teams.', image, noindex = false } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = image ? new URL(image, Astro.site).href : new URL('/og.png', Astro.site).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${Astro.site}#website`,
      url: Astro.site,
      name: 'Verdikt',
      description,
      publisher: { '@id': `${Astro.site}#organization` },
      inLanguage: 'en-IN',
      potentialAction: {
        '@type': 'SearchAction',
        target: { '@type': 'EntryPoint', urlTemplate: `${Astro.site}/?q={search_term_string}` },
        'query-input': 'required name=search_term_string',
      },
    },
    {
      '@type': 'Organization',
      '@id': `${Astro.site}#organization`,
      name: 'Verdikt',
      url: Astro.site,
      logo: { '@type': 'ImageObject', url: new URL('/favicon.svg', Astro.site).href },
      description: 'Interview management for modern teams. Built for Indian hiring teams.',
    },
    {
      '@type': 'SoftwareApplication',
      name: 'Verdikt',
      applicationCategory: 'BusinessApplication',
      operatingSystem: 'Web',
      description,
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'INR' },
    },
  ],
};
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="keywords" content="interview management, HR software, ATS, recruitment, Indian hiring, AI resume screening, candidate tracking, hiring pipeline, recruitment software India" />
		<meta name="theme-color" content="#040511" />
		{noindex ? <meta name="robots" content="noindex, nofollow" /> : null}

		<link rel="canonical" href={canonicalURL.href} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL.href} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:site_name" content="Verdikt" />
		<meta property="og:locale" content="en_IN" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={canonicalURL.href} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />

		<meta name="generator" content={Astro.generator} />

		<!-- AOS scroll animations -->
		<link rel="stylesheet" href="https://unpkg.com/aos@2.3.4/dist/aos.css" />
		<!-- Lucide icons -->
		<script src="https://unpkg.com/lucide@latest" defer></script>

		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
	</head>
	<body>
		<slot />

		<script is:inline>
			document.addEventListener('DOMContentLoaded', function () {
				if (typeof window.AOS !== 'undefined') window.AOS.init({ duration: 600, once: true, offset: 40 });
				if (typeof window.lucide !== 'undefined') window.lucide.createIcons();
			});
		</script>
		<script src="https://unpkg.com/aos@2.3.4/dist/aos.js" defer></script>
	</body>
</html>

<style is:global>
	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}

	html {
		scroll-behavior: smooth;
	}

	html,
	body {
		margin: 0;
		padding: 0;
		width: 100%;
		min-height: 100%;
		background: var(--app-bg);
		color: var(--text-primary);
		font-family: var(--font-geist-sans);
		font-size: 16px;
		line-height: 1.6;
		-webkit-font-smoothing: antialiased;
	}
</style>
